Package: eVCGsampler
Type: Package
Title: VCG Sampling using Energy-Based Covariate Balancing
Version: 0.9.5
Authors@R: c(
    person(
      "Andreas", "Schulz",
      email = "andreas.schulz2@sanofi.com",
      role = c("aut", "cre"),
